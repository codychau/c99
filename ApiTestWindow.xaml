<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="C99.ApiTestWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="API 测试工具" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="BaseUrlBlock" FontFamily="Consolas" FontSize="14"
                       VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="EndpointCombo" Grid.Column="1"
                      FontFamily="Consolas" FontSize="14" Height="34"
                      IsEditable="True" Margin="0,0,8,0"
                      SelectionChanged="OnEndpointChanged"/>
            <ComboBox x:Name="MethodCombo" Grid.Column="2"
                      FontSize="14" Width="72" Height="34" Margin="0,0,8,0"
                      SelectionChanged="OnMethodChanged"/>
            <ProgressRing x:Name="LoadingRing" Grid.Column="3"
                          Width="24" Height="24" IsActive="False"
                          Visibility="Collapsed" Margin="0,0,8,0"/>
            <Button x:Name="SendBtn" Grid.Column="4"
                    Content="发送请求" FontSize="14" Height="34" Width="100"
                    Click="OnSendClick"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="请求体：" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <TextBox x:Name="BodyTextBox" Grid.Row="3"
                 FontFamily="Consolas" FontSize="13"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 PlaceholderText="输入 JSON 请求体..."
                 Margin="0,0,0,12"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
            <TextBlock Text="响应：" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" FontFamily="Consolas" FontSize="14" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBox x:Name="ResponseTextBox" Grid.Row="5"
                 FontFamily="Consolas" FontSize="13"
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 PlaceholderText="响应结果将显示在这里..."/>
    </Grid>
</Window>
